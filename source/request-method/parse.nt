import {
  this.private.parse {_symbol},
  this.request-method {
    DELETE,
    GET,
    HEAD,
    OPTIONS,
    PATCH,
    POST,
    PUT,
    TRACE,
    request-method,
  },
  zonk.parse {report-unexpected-input, zonk},
}

constant request-method-parser<c>: zonk(c, request-method) {
  (k) => {
    try method-string = _symbol(k);
    let method-or-none on method-string =
      if eq-string(method-string, "GET") {
        Right(GET)
      } else-if eq-string(method-string, "HEAD") {
        Right(HEAD)
      } else-if eq-string(method-string, "POST") {
        Right(POST)
      } else-if eq-string(method-string, "PUT") {
        Right(PUT)
      } else-if eq-string(method-string, "DELETE") {
        Right(DELETE)
      } else-if eq-string(method-string, "OPTIONS") {
        Right(OPTIONS)
      } else-if eq-string(method-string, "TRACE") {
        Right(TRACE)
      } else-if eq-string(method-string, "PATCH") {
        Right(PATCH)
      } else {
        Left(Unit)
      };
    let _ = method-string;
    match method-or-none {
    | Right(method) =>
      Right(method)
    | Left(_) =>
      report-unexpected-input("request method")
    }
  }
}
