import {
  core.list.eq {member},
  noa.gen {gen},
  noa.gen.custom.string {Config, string-gen},
}

data _config {
| _Config(
    blacklist: list(rune),
    min-length: int,
  )
}

inline _adjusted-string-gen(!c: _config) -> gen(string) {
  let _Config {min-length, blacklist} = c;
  string-gen(Config {
    min-length,
    max-length := none,
    rune-generator := none,
    rune-acceptor := {
      (r) => {
        pin bk = blacklist;
        pin r = r;
        pin k = core.rune.eq.as-eq;
        not(member(k, bk, r))
      }
    },
  })
}
