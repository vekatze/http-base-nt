import {
  core.int.show {show-int},
  core.show {Show, show},
  core.string {join},
  this.header.show {show-header},
  this.response {Response, response},
}

define _get-status-code-string(code: int) -> &string {
  match code {
  | 200 =>
    "OK"
  | 400 =>
    "Bad Request"
  | 500 =>
    "Internal Server Error"
  | _ =>
    "UNKNOWN"
  }
}

define show-response(resp: response) -> string {
  let Response {status-code, fields, body} = resp;
  join(List[
    *"HTTP/1.1",
    *" ",
    show-int(status-code),
    *" ",
    *_get-status-code-string(status-code),
    *"\r\n",
    show-header(fields),
    *"\r\n",
    body,
  ])
}

constant as-show: show(response) {
  Show {show := show-response}
}
