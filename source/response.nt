import {
  core.int.show {show-int},
  core.string {string-byte-length},
  this.field {Field},
  this.header {header},
}

data response {
| Response(
    status-code: int,
    fields: header,
    body: string,
  )
}

define string-response(status-code: int, body: string) -> response {
  let len on body = string-byte-length(body);
  Response {
    status-code,
    fields := List[Field(*"content-length", show-int(len))],
    body,
  }
}
