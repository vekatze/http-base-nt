import {
  core.list {for-each},
  noa.gen {Gen, gen},
  noa.gen.pair {pair-gen},
  this.header {header},
  this.header.gen {header-gen},
  this.private.gen {_Config, _adjusted-string-gen},
  this.request {Request, request},
  this.request-method {request-method},
  this.request-method.gen {request-method-gen},
}

constant _tuple-requests: gen(pair(request-method, pair(string, pair(header, string)))) {
  let rune-blacklist = List[` `, `\u{8}`, `\u{9}`, `\u{A}`, `\u{B}`, `\u{C}`, `\u{D}`];
  let c = _Config{blacklist := rune-blacklist, min-length := 1};
  let !string-gen = _adjusted-string-gen(c);
  pair-gen(request-method-gen, pair-gen(string-gen, pair-gen(header-gen, string-gen)))
}

constant request-gen: gen(request) {
  let rune-blacklist = List[` `, `\u{8}`, `\u{9}`, `\u{A}`, `\u{B}`, `\u{C}`, `\u{D}`];
  let c = _Config{blacklist := rune-blacklist, min-length := 1};
  let !string-gen = _adjusted-string-gen(c);
  let Gen{generate} = request-method-gen;
  let Gen{generate := !generate-string} = string-gen;
  let Gen{generate := !generate-header} = header-gen;
  let Gen{shrink := !shrink-tuple} = _tuple-requests;
  Gen{
    generate := {
      (size) => {
        let method = generate(size);
        let path = generate-string(size);
        let fields = generate-header(size);
        let body = generate-string(size);
        Request{method, path, fields, body}
      }
    },
    shrink := {
      (req) => {
        let Request{method, path, fields, body} = req;
        let tup = Pair(method, Pair(path, Pair(fields, body)));
        let cands = shrink-tuple(tup);
        for-each(cands, (cand) => {
          let Pair(method, Pair(path, Pair(fields, body))) = cand;
          Request{method, path, fields, body}
        })
      }
    },
  }
}
